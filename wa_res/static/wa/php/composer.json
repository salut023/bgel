{
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": true,
    "vendor-dir": "."
  },
  "require": {
    "phpmailer/phpmailer": "^7.0"
  },
  "scripts": {
    "post-update-cmd": [
      "find phpmailer/phpmailer/language -type f ! -name 'phpmailer.lang-fr.php' -delete",
      "find . -type f -name '*.md' -delete",
      "find . -type f -name 'COMMITMENT' -delete",
      "find . -type f -name 'LICENSE' -delete",
      "find . -type f -name 'VERSION' -delete",
      "rm -f composer.lock"
    ]
  }
}
